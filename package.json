{
  "name": "agent-secrets-vault",
  "version": "0.1.3",
  "description": "Local MCP-compatible credential broker — AI agents call external services without ever receiving raw credentials",
  "main": "dist/cli/index.js",
  "bin": {
    "asv": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "config",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/cooperdunkin/agent-secrets-vault.git"
  },
  "homepage": "https://github.com/cooperdunkin/agent-secrets-vault",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start:mcp": "ASV_IDENTITY=local-dev node dist/mcp/server.js",
    "test": "npx tsx src/tests/index.ts",
    "test:built": "node dist/tests/index.js",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "js-yaml": "^4.1.0",
    "keytar": "^7.9.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/keytar": "^4.4.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "secrets",
    "vault",
    "ai-agents",
    "credentials"
  ],
  "license": "MIT"
}
