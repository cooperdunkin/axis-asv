{
  "name": "agent-secrets-vault",
  "version": "0.1.0",
  "description": "Local MCP-compatible credential broker — AI agents call external services without ever receiving raw credentials",
  "main": "dist/cli/index.js",
  "bin": {
    "asv": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "start:mcp": "ASV_IDENTITY=local-dev node dist/mcp/server.js",
    "test": "node --import tsx/esm src/tests/index.ts",
    "test:built": "node dist/tests/index.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.8.0",
    "js-yaml": "^4.1.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": ["mcp", "secrets", "vault", "ai-agents", "credentials"],
  "license": "MIT"
}
